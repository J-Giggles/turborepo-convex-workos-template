{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@repo/backend#dev"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@repo/backend#dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "cache": false,
      "inputs": ["src/check.ts", "src/*.ts", "../../apps/*/.env.local", "../../apps/*/.env"]
    }
  }
}
