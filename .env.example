# =============================================================================
# turborepo-convex-workos-template — master env reference
# =============================================================================
#
# This file is the single reference for every env var the template uses.
#
# Where each var actually lives at runtime depends on who reads it:
#
#   • Convex deployment (server)   → set with `npx convex env set NAME 'value'`
#                                    from inside `packages/backend/`.
#   • packages/backend/.env.local  → only CONVEX_DEPLOYMENT + CONVEX_URL
#                                    (auto-populated by `pnpm convex:setup`).
#   • apps/website/.env.local      → public NEXT_PUBLIC_* only.
#   • apps/dashboard/.env.local    → server WORKOS_* + VERCEL_* + public NEXT_PUBLIC_*.
#   • apps/tenant/.env.local       → server WORKOS_* + public NEXT_PUBLIC_*.
#   • apps/native/.env             → bare RN env (read via react-native-dotenv).
#
# Validation:
#
#   `pnpm dev` runs `@repo/env#check` first, which validates every per-app
#   `.env.local` against its schema in `packages/env/src/<app>.ts`. Missing
#   files are skipped (so the check is no-op until an app is scaffolded).
#
# To copy this file into the right places:
#
#   cp .env.example apps/website/.env.local      # then strip server-only sections
#   cp .env.example apps/dashboard/.env.local    # keeps almost everything
#   cp .env.example apps/tenant/.env.local       # keeps WorkOS + Convex
#   cp .env.example apps/native/.env             # keeps native section only
#
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Convex
# -----------------------------------------------------------------------------
# CONVEX_DEPLOYMENT and CONVEX_URL are auto-populated in
# packages/backend/.env.local by `pnpm convex:setup`. Do not edit manually.
# Every Next.js app needs NEXT_PUBLIC_CONVEX_URL set to the same URL.
# -----------------------------------------------------------------------------

# (auto-populated, server side, read only by convex CLI)
CONVEX_DEPLOYMENT=
CONVEX_URL=

# Required by every Next.js app to talk to Convex.
NEXT_PUBLIC_CONVEX_URL=

# CI/build only — required when deploying via Vercel without `convex login`.
# Generate with: cd packages/backend && npx convex deploy --cmd-url-env-var-name= --cmd 'echo $CONVEX_DEPLOY_KEY'
CONVEX_DEPLOY_KEY=


# -----------------------------------------------------------------------------
# 2. WorkOS — server side (Convex deployment + dashboard + tenant apps)
# -----------------------------------------------------------------------------
# Get these from https://dashboard.workos.com after signing up.
# • API Keys page → WORKOS_CLIENT_ID + WORKOS_API_KEY
# • AuthKit → Domain          → WORKOS_AUTHKIT_DOMAIN  (e.g. https://acme.authkit.app)
# • Webhooks → Endpoint       → WORKOS_WEBHOOK_SECRET
# • Webhook URL to register   → https://<your-deployment>.convex.site/workos/webhook
#
# Convex deployment env vars are NOT read from this file — they live on the
# Convex side. Use:
#   cd packages/backend && npx convex env set WORKOS_AUTHKIT_DOMAIN 'https://...'
# -----------------------------------------------------------------------------

WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_WEBHOOK_SECRET=

# AuthKit issuer URL. Used both server-side (auth.config.ts) and client-side
# (browser AuthKit SDK) — the public copy below mirrors this value.
WORKOS_AUTHKIT_DOMAIN=

# Cookie session sealer for `@workos-inc/authkit-nextjs`. Min 32 chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKOS_COOKIE_PASSWORD=

# AuthKit redirect URI after sign-in. One per app:
#   dashboard local: http://localhost:3001/callback
#   tenant   local:  http://{slug}.localhost:3002/callback
#   prod:            https://app.example.com/callback
WORKOS_REDIRECT_URI=


# -----------------------------------------------------------------------------
# 3. WorkOS — client side (Next.js apps that need AuthKit in the browser)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_AUTHKIT_DOMAIN=


# -----------------------------------------------------------------------------
# 4. Vercel REST API — dashboard app only (custom-domain provisioning)
# -----------------------------------------------------------------------------
# Used by the dashboard to add/verify custom domains on the tenant Vercel project.
# • Token: https://vercel.com/account/tokens (scope: full account or per-team)
# • IDs:   Vercel dashboard → Project Settings → General
# -----------------------------------------------------------------------------

VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID_TENANT=


# -----------------------------------------------------------------------------
# 5. Per-app public URLs (Next.js apps)
# -----------------------------------------------------------------------------

# Marketing website canonical URL (metadata, OG, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dashboard canonical URL (used in invite emails, redirect targets).
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# Apex domain for the multi-tenant runtime — proxy.ts splits the request
# host as `{slug}.{NEXT_PUBLIC_PLATFORM_ROOT}`. Local dev convention:
# `localhost:3002`. In production this is your apex (e.g. `example.com`).
NEXT_PUBLIC_PLATFORM_ROOT=localhost:3002


# -----------------------------------------------------------------------------
# 6. Native app (bare React Native)
# -----------------------------------------------------------------------------
# Read at app boot via react-native-dotenv. Names DO NOT use NEXT_PUBLIC_*.
# -----------------------------------------------------------------------------

AUTHKIT_DOMAIN=
AUTHKIT_REDIRECT_URI=notescontract://callback


# -----------------------------------------------------------------------------
# 7. Optional integrations (Convex deployment only — env-gated)
# -----------------------------------------------------------------------------
# When unset, the corresponding Convex helper (getR2() / getResend()) returns
# null and callers no-op. Set on Convex deployment when you need the feature:
#   cd packages/backend && npx convex env set RESEND_API_KEY 'rs_xxx'
# -----------------------------------------------------------------------------

# Resend transactional email — https://resend.com/api-keys
RESEND_API_KEY=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
